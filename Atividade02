    println("Digite a operação: ")
    var op = readln().replace(" ", "")

    if (op.length < 9) {
        println("A expressão deve ter no mínimo 9 caracteres.")
        return
    }

    try {

        while (op.contains("(")) {

            val inicio = op.lastIndexOf("(")
            val fim = op.indexOf(")", inicio)

            val dentro = op.substring(inicio + 1, fim)
            val resultadoParenteses = calcularSimples(dentro)

            op = op.replaceRange(inicio, fim + 1, resultadoParenteses.toString())
        }

        val resultadoFinal = calcularSimples(op)

        println("Resultado: $resultadoFinal")

    } catch (e: Exception) {
        println("Expressão inválida.")
    }
}

fun calcularSimples(exp: String): Double {

    var expressao = exp

    // Multiplicação e divisão primeiro
    while (expressao.contains("*") || expressao.contains("/")) {

        val regex = Regex("""(\d+\.?\d*)([\*/])(\d+\.?\d*)""")
        val match = regex.find(expressao) ?: break

        val n1 = match.groupValues[1].toDouble()
        val operador = match.groupValues[2]
        val n2 = match.groupValues[3].toDouble()

        val resultado = if (operador == "*") n1 * n2 else n1 / n2

        expressao = expressao.replaceFirst(match.value, resultado.toString())
    }

    // Depois soma e subtração
    while (expressao.contains("+") || expressao.contains("-")) {

        val regex = Regex("""(\d+\.?\d*)([+-])(\d+\.?\d*)""")
        val match = regex.find(expressao) ?: break

        val n1 = match.groupValues[1].toDouble()
        val operador = match.groupValues[2]
        val n2 = match.groupValues[3].toDouble()

        val resultado = if (operador == "+") n1 + n2 else n1 - n2

        expressao = expressao.replaceFirst(match.value, resultado.toString())
    }

    return expressao.toDouble()
}
